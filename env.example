# Copy this file to ".env" (same folder as send_region_dashboards.py) and
# fill in the real values. Requires: pip install --break-system-packages python-dotenv
#
# Run find_smtp_settings.py first to confirm the correct SMTP_HOST/SMTP_PORT
# for webmail.denave.com -- don't guess, since a wrong host just times out.

SMTP_HOST=REPLACE_WITH_CONFIRMED_HOST
SMTP_PORT=587
SMTP_USER=canonreport@denave.com
SMTP_PASSWORD=REPLACE_WITH_MAILBOX_PASSWORD
SMTP_FROM=canonreport@denave.com
